# RunGuard Configuration
RUNGUARD_ENV=local
RUNGUARD_LOG_LEVEL=INFO

# API
RUNGUARD_API_URL=http://localhost:8000
RUNGUARD_API_KEY=your-runguard-api-key
RUNGUARD_WEBHOOK_SECRET=your-webhook-bearer-token

# Claude API (required for LLM reasoning)
RUNGUARD_ANTHROPIC_API_KEY=your-api-key-here
RUNGUARD_CLAUDE_MODEL=claude-sonnet-4-20250514

# Kubernetes
RUNGUARD_KUBECONFIG=~/.kube/config
RUNGUARD_K8S_NAMESPACE=runguard

# Audit
RUNGUARD_AUDIT_STORE_PATH=./data/audit

# Notifications
RUNGUARD_SLACK_WEBHOOK_URL=
